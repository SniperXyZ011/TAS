# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=tas_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=tactical_armory

DATABASE_URL=postgres://tas_user:change_me_in_production@localhost:5432/tactical_armory?sslmode=disable

# ─── Server ──────────────────────────────────────────────────────────────────
SERVER_PORT=8080
ENV=development           # development | production
LOG_LEVEL=debug           # debug | info | warn | error

# ─── Security ────────────────────────────────────────────────────────────────
# Admin API key — used ONLY for node registration and admin routes
# Generate with: openssl rand -hex 32
ADMIN_API_KEY=replace_with_32_byte_hex_secret

# ─── Rate Limiting ───────────────────────────────────────────────────────────
# Max requests per second per node before 429 is returned
NODE_RATE_LIMIT_RPS=10
